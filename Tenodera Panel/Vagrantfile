# -*- mode: ruby -*-
# vi: set ft=ruby :

# ── Configuration ────────────────────────────────────────
# ⚠️  DEVELOPMENT ONLY — Default credentials below are for local Vagrant VMs.
#     Do NOT use these in production. Override via environment variables:
#
#   TENODERA_USER     — Linux user to create on VMs (default: tenodera)
#   TENODERA_PASS     — Password for the user (default: tenodera)
#   TENODERA_SSH_KEY  — SSH public key to inject (optional)
VM_USER    = ENV.fetch("TENODERA_USER",    "tenodera")
VM_PASS    = ENV.fetch("TENODERA_PASS",    "tenodera")
VM_SSH_KEY = ENV.fetch("TENODERA_SSH_KEY", "")

NODES = [
  { name: "tenodera-remote-1", ip: "192.168.56.10" },
  { name: "tenodera-remote-2", ip: "192.168.56.11" },
  { name: "tenodera-remote-3", ip: "192.168.56.12" },
  { name: "tenodera-remote-4", ip: "192.168.56.13" },
  { name: "tenodera-remote-5", ip: "192.168.56.14" },
  { name: "tenodera-remote-6", ip: "192.168.56.15" },
]

Vagrant.configure("2") do |config|
  config.vm.box = "debian/bookworm64"

  NODES.each do |node|
    config.vm.define node[:name] do |n|
      n.vm.hostname = node[:name]
      n.vm.network "private_network", ip: node[:ip]

      n.vm.provider "virtualbox" do |vb|
        vb.memory = "2048"
        vb.cpus = 2
        vb.name = node[:name]
      end

      n.vm.provision "shell", inline: <<-SHELL
        set -e

        # Update system
        apt-get update && apt-get upgrade -y

        # Install base tools + tenodera dependencies
        apt-get install -y make htop net-tools vim sshpass

        # Enable SSH password authentication
        sed -i 's/^#\\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
        sed -i 's/^#\\?KbdInteractiveAuthentication.*/KbdInteractiveAuthentication yes/' /etc/ssh/sshd_config
        systemctl restart sshd

        # Create VM user with sudo access
        if ! id #{VM_USER} &>/dev/null; then
          useradd -m -s /bin/bash -G sudo #{VM_USER}
          echo "#{VM_USER} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/#{VM_USER}
          chmod 0440 /etc/sudoers.d/#{VM_USER}
        fi

        # Set user password
        echo "#{VM_USER}:#{VM_PASS}" | chpasswd

        # Install SSH public key (if provided)
        if [ -n "#{VM_SSH_KEY}" ]; then
          mkdir -p /home/#{VM_USER}/.ssh
          echo "#{VM_SSH_KEY}" > /home/#{VM_USER}/.ssh/authorized_keys
          chmod 700 /home/#{VM_USER}/.ssh
          chmod 600 /home/#{VM_USER}/.ssh/authorized_keys
          chown -R #{VM_USER}:#{VM_USER} /home/#{VM_USER}/.ssh
        fi

        # Install Rust for the VM user
        if [ ! -d /home/#{VM_USER}/.cargo ]; then
          su - #{VM_USER} -c 'curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'
        fi

        echo ""
        echo "=== User #{VM_USER} created ==="
        echo "SSH: ssh #{VM_USER}@#{node[:ip]}"
        echo "Password: #{VM_PASS}"
        echo ""
      SHELL
    end
  end
end
